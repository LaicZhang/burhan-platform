# Supabase Connection Settings
# Project URL (Supabase dashboard > Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Anon/Public Key (starts with sb_publishable_ or eyJ...)
SUPABASE_KEY=your-anon-key

# Service Role Key (Server-only admin key, starts with sb_secret_ or eyJ...)
SUPABASE_SECRET_KEY=your-service-role-key

# Platform SEO Settings
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SITE_NAME=Burhan

# Cloudflare Turnstile Spam Protection (Optional, required for Digital Observatory submissions)
# Turnstile Site Key (Public)
NUXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Turnstile Secret Key (Server-only)
NUXT_TURNSTILE_SECRET_KEY=your-turnstile-secret-key
